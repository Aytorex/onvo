{
  "$schema": "https://eips.ethereum.org/assets/eip-7730/erc7730-v2.schema.json",
  "context": {
    "$id": "Onvo InvoiceRegistry",
    "contract": {}
  },
  "metadata": {
    "owner": "Onvo",
    "contractName": "InvoiceRegistry",
    "info": {
      "url": "https://github.com/onvo/onvo"
    }
  },
  "display": {
    "formats": {
      "registerWithWorldId(uint256 root,uint256 groupId,uint256 nullifierHash,uint256[8] proof)": {
        "intent": "Verify emitter with World ID",
        "fields": [
          {
            "path": "root",
            "label": "Merkle root",
            "format": "raw"
          },
          {
            "path": "groupId",
            "label": "Group ID",
            "format": "raw"
          },
          {
            "path": "nullifierHash",
            "label": "Nullifier hash",
            "format": "raw"
          }
        ]
      },
      "createInvoice(uint256 invoiceId,bytes32 invoiceHash_,address emitter,address recipient,uint256 amount,address token,uint256 year,uint256 month)": {
        "intent": "Register verified invoice on-chain",
        "interpolatedIntent": "Invoice {year}-{month} — id {invoiceId} · total {amount} · client {recipient} · pay to {emitter} · ref {invoiceHash_}",
        "fields": [
          {
            "path": "invoiceId",
            "label": "Packed invoice ID (F-…-YYYY-MM-seq)",
            "format": "raw"
          },
          {
            "path": "invoiceHash_",
            "label": "Payment reference (PDF hash)",
            "format": "bytes32"
          },
          {
            "path": "emitter",
            "label": "Issuer wallet (receives funds)",
            "format": "addressName"
          },
          {
            "path": "recipient",
            "label": "Client wallet",
            "format": "addressName"
          },
          {
            "path": "amount",
            "label": "Total amount (TTC, token units)",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "token"
            }
          },
          {
            "path": "token",
            "label": "Currency (settlement token)",
            "format": "addressName"
          },
          {
            "path": "year",
            "label": "Invoice year (calendar)",
            "format": "raw"
          },
          {
            "path": "month",
            "label": "Invoice month (1–12)",
            "format": "raw"
          }
        ]
      },
      "payInvoice(uint256 invoiceId)": {
        "intent": "Pay invoice — ERC-20 transfer to issuer on-chain",
        "interpolatedIntent": "Pay invoice ID {invoiceId} (amount and token from contract storage)",
        "fields": [
          {
            "path": "invoiceId",
            "label": "Invoice ID",
            "format": "raw"
          }
        ]
      },
      "cancelInvoice(uint256 invoiceId)": {
        "intent": "Cancel pending invoice",
        "interpolatedIntent": "Cancel invoice ID {invoiceId}",
        "fields": [
          {
            "path": "invoiceId",
            "label": "Invoice ID",
            "format": "raw"
          }
        ]
      },
      "addAllowedToken(address token)": {
        "intent": "Allow settlement token",
        "fields": [
          {
            "path": "token",
            "label": "Token contract",
            "format": "addressName"
          }
        ]
      },
      "transferOwnership(address newOwner)": {
        "intent": "Transfer contract ownership",
        "fields": [
          {
            "path": "newOwner",
            "label": "New owner",
            "format": "addressName"
          }
        ]
      }
    }
  }
}
