{
  "$schema": "https://raw.githubusercontent.com/LedgerHQ/clear-signing-erc7730-registry/master/specs/erc7730-tests.schema.json",
  "tests": [
    {
      "description": "createInvoice: packed invoice id + calendar year/month + PDF hash, issuer, client, amount, token (same logical vector as pre–invoice-id schema; year/month 2026/4, seq 1).",
      "rawTx": "",
      "expectedTexts": [
        "Register verified invoice on-chain",
        "Packed invoice ID (F-…-YYYY-MM-seq)",
        "Payment reference (PDF hash)",
        "e91d2dc6d2f85c28aa0ebc60805a50e71a1e8504d939a7838f5d95d5e28b3ba6",
        "Issuer wallet (receives funds)",
        "f39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
        "Client wallet",
        "70997970C51812dc3A010C7d01b50e0d17dc79C8",
        "Total amount (TTC, token units)",
        "Currency (settlement token)",
        "3600000000000000000000000000000000000000",
        "Invoice year (calendar)",
        "Invoice month (1–12)"
      ]
    },
    {
      "description": "payInvoice: wallet shows invoice_id from calldata; total_amount, currency, recipient_wallet, issuer_name, client_name, items_summary come from contract storage + token metadata (not in calldata) — dApp or simulation should complement Ledger.",
      "rawTx": "",
      "expectedTexts": [
        "Pay invoice — ERC-20 transfer to issuer on-chain",
        "Invoice ID",
        "42"
      ]
    },
    {
      "description": "cancelInvoice: invoice_id only in calldata.",
      "rawTx": "",
      "expectedTexts": ["Cancel pending invoice", "Invoice ID", "7"]
    },
    {
      "description": "registerWithWorldId: emitter verification; not invoice payment UI.",
      "rawTx": "",
      "expectedTexts": [
        "Verify emitter with World ID",
        "Merkle root",
        "Group ID",
        "Nullifier hash"
      ]
    }
  ]
}
