# ── Alchemy (RPC provider for Arc Testnet) ──
ALCHEMY_API_KEY="DUMMY"
ALCHEMY_ENDPOINT_URL_ARC_TESTNET=""

# ── WalletConnect (wallet modal) ──
WALLET_CONNECT_PROJECT_ID="DUMMY"
WORLD_RP_SIGNING_KEY="sk_xxxxx"

# ── Trusted verifier (server-side private key for registerEmitter on-chain) ──
# Must correspond to the trustedVerifier address in InvoiceRegistry.
# For local Hardhat (account[0]): 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TRUSTED_VERIFIER_PRIVATE_KEY=""

# ── World ID (proof of humanity — emitter verification) ──
NEXT_PUBLIC_WORLD_APP_ID="app_staging_xxxxx"
NEXT_PUBLIC_WORLD_RP_ID="rp_staging_xxxxx"
NEXT_PUBLIC_WORLD_ID_GROUP_ID="1"

# ── Dev mode (shows a "Fill form" button for quick testing) ──
NEXT_PUBLIC_DEV_MODE=true

# ── InvoiceRegistry smart contract ──
# Address of the deployed InvoiceRegistry contract.
# For local Hardhat: deploy with `npx hardhat ignition deploy ignition/modules/InvoiceRegistry.local.ts --network localhost`
NEXT_PUBLIC_INVOICE_REGISTRY_ADDRESS=""
# Chain ID where the contract is deployed (31337 = Hardhat local, 5042002 = Arc Testnet)
NEXT_PUBLIC_INVOICE_REGISTRY_CHAIN_ID=5042002
# Block number from which to start indexing events (0 for local)
NEXT_PUBLIC_INVOICE_REGISTRY_FROM_BLOCK=0

# ── Stablecoin token addresses (ERC-20 on the target chain) ──
# USDC contract address
NEXT_PUBLIC_TOKEN_USDC=0x3600000000000000000000000000000000000000
# EURC contract address
NEXT_PUBLIC_TOKEN_EURC=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
